{
  "name": "@serverforge/schemas",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./sites": {
      "import": "./dist/sites.js",
      "types": "./dist/sites.d.ts"
    },
    "./domains": {
      "import": "./dist/domains.js",
      "types": "./dist/domains.d.ts"
    },
    "./auth": {
      "import": "./dist/auth.js",
      "types": "./dist/auth.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --project tsconfig.build.json --watch"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}