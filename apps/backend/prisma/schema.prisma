generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───

enum UserRole {
  admin
  developer
  viewer
}

enum ServerStatus {
  online
  offline
  unknown
}

enum AuthType {
  key
  password
}

enum SiteStatus {
  provisioning
  live
  stopped
  error
}

enum StackType {
  nodejs
  php
  laravel
  python
  static
  docker
}

enum TunnelStatus {
  connected
  disconnected
  installing
}

enum DeployStatus {
  running
  success
  failed
}

enum JobStatus {
  pending
  running
  done
  failed
}

enum AlertType {
  cpu
  ram
  disk
  site_down
  deploy_fail
}

// ─── Teams ───

model Team {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  plan      String   @default("free")
  createdAt DateTime @default(now()) @map("created_at")

  users               User[]
  servers             Server[]
  sites               Site[]
  sshKeys             SshKey[]
  cfAccounts          CfAccount[]
  cronJobs            CronJob[]
  firewallRules       FirewallRule[]
  notificationChannels NotificationChannel[]
  alertRules          AlertRule[]
  jobHistory          JobHistory[]

  @@map("teams")
}

// ─── Users ───

model User {
  id                  String    @id @default(uuid())
  email               String    @unique
  passwordHash        String    @map("password_hash")
  role                UserRole  @default(viewer)
  totpSecretEncrypted String?   @map("totp_secret_encrypted")
  totpEnabled         Boolean   @default(false) @map("totp_enabled")
  teamId              String    @map("team_id")
  lastLoginAt         DateTime? @map("last_login_at")
  createdAt           DateTime  @default(now()) @map("created_at")

  team        Team          @relation(fields: [teamId], references: [id])
  userServers UserServer[]
  userSites   UserSite[]
  auditLogs   AuditLog[]
  deploys     Deploy[]

  @@map("users")
}

// ─── User-Server assignments (RBAC) ───

model UserServer {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  serverId   String   @map("server_id")
  permission String   @default("view")
  createdAt  DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id])
  server Server @relation(fields: [serverId], references: [id])

  @@unique([userId, serverId])
  @@map("user_servers")
}

// ─── User-Site assignments (RBAC) ───

model UserSite {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  siteId     String   @map("site_id")
  permission String   @default("view")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])
  site Site @relation(fields: [siteId], references: [id])

  @@unique([userId, siteId])
  @@map("user_sites")
}

// ─── Servers ───

model Server {
  id                String       @id @default(uuid())
  name              String
  host              String
  port              Int          @default(22)
  username          String
  authType          AuthType     @default(key) @map("auth_type")
  sshKeyId          String?      @map("ssh_key_id")
  passwordEncrypted String?      @map("password_encrypted")
  osInfo            Json?        @map("os_info")
  status            ServerStatus @default(unknown)
  tags              Json         @default("[]")
  teamId            String       @map("team_id")
  createdAt         DateTime     @default(now()) @map("created_at")
  deletedAt         DateTime?    @map("deleted_at")

  team          Team           @relation(fields: [teamId], references: [id])
  sshKey        SshKey?        @relation(fields: [sshKeyId], references: [id])
  tunnel        Tunnel?
  sites         Site[]
  userServers   UserServer[]
  metrics       Metric[]
  cronJobs      CronJob[]
  firewallRules FirewallRule[]

  @@index([teamId])
  @@map("servers")
}

// ─── SSH Keys ───

model SshKey {
  id                  String   @id @default(uuid())
  name                String
  publicKey           String   @map("public_key")
  privateKeyEncrypted String   @map("private_key_encrypted")
  fingerprint         String
  teamId              String   @map("team_id")
  createdAt           DateTime @default(now()) @map("created_at")

  team    Team     @relation(fields: [teamId], references: [id])
  servers Server[]

  @@map("ssh_keys")
}

// ─── Cloudflare Tunnels ───

model Tunnel {
  id              String        @id @default(uuid())
  serverId        String        @unique @map("server_id")
  cfTunnelId      String        @map("cf_tunnel_id")
  name            String
  status          TunnelStatus  @default(disconnected)
  ingressRoutes   Json          @default("[]")
  credentialsPath String?       @map("credentials_path")
  installedAt     DateTime?     @map("installed_at")
  createdAt       DateTime      @default(now()) @map("created_at")

  server Server @relation(fields: [serverId], references: [id])

  @@map("tunnels")
}

// ─── Cloudflare Accounts ───

model CfAccount {
  id                String   @id @default(uuid())
  name              String
  apiTokenEncrypted String   @map("api_token_encrypted")
  email             String?
  accountId         String?  @map("account_id")
  teamId            String   @map("team_id")
  createdAt         DateTime @default(now()) @map("created_at")

  team  Team     @relation(fields: [teamId], references: [id])
  zones CfZone[]

  @@map("cf_accounts")
}

// ─── Cloudflare Zones ───

model CfZone {
  id           String    @id @default(uuid())
  cfAccountId  String    @map("cf_account_id")
  zoneId       String    @map("zone_id")
  zoneName     String    @map("zone_name")
  sslMode      String?   @map("ssl_mode")
  proxyStatus  Boolean?  @map("proxy_status")
  plan         String?
  syncedAt     DateTime? @map("synced_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  cfAccount   CfAccount   @relation(fields: [cfAccountId], references: [id])
  dnsRecords  DnsRecord[]

  @@map("cf_zones")
}

// ─── DNS Records ───

model DnsRecord {
  id             String    @id @default(uuid())
  zoneId         String    @map("zone_id")
  cfRecordId     String?   @map("cf_record_id")
  type           String
  name           String
  content        String
  proxied        Boolean   @default(false)
  ttl            Int       @default(1)
  managedByPanel Boolean   @default(true) @map("managed_by_panel")
  syncedAt       DateTime? @map("synced_at")

  zone CfZone @relation(fields: [zoneId], references: [id])

  @@index([zoneId])
  @@map("dns_records")
}

// ─── Sites ───

model Site {
  id          String     @id @default(uuid())
  serverId    String     @map("server_id")
  name        String
  domain      String
  subdomain   String?
  stackType   StackType  @map("stack_type")
  rootPath    String?    @map("root_path")
  port        Int?
  phpVersion  String?    @map("php_version")
  processName String?    @map("process_name")
  gitUrl      String?    @map("git_url")
  gitBranch   String?    @map("git_branch")
  status      SiteStatus @default(provisioning)
  nginxConfig String?    @map("nginx_config")
  teamId      String     @map("team_id")
  createdAt   DateTime   @default(now()) @map("created_at")
  deletedAt   DateTime?  @map("deleted_at")

  server       Server        @relation(fields: [serverId], references: [id])
  team         Team          @relation(fields: [teamId], references: [id])
  envVars      SiteEnvVar[]
  deploys      Deploy[]
  userSites    UserSite[]
  uptimeChecks UptimeCheck[]

  @@unique([domain])
  @@index([serverId])
  @@map("sites")
}

// ─── Site Environment Variables ───

model SiteEnvVar {
  id              String   @id @default(uuid())
  siteId          String   @map("site_id")
  key             String
  valueEncrypted  String   @map("value_encrypted")
  version         Int
  createdAt       DateTime @default(now()) @map("created_at")
  createdBy       String   @map("created_by")

  site Site @relation(fields: [siteId], references: [id])

  @@unique([siteId, key, version])
  @@index([siteId, key, version])
  @@map("site_env_vars")
}

// ─── Deploy History ───

model Deploy {
  id          String       @id @default(uuid())
  siteId      String       @map("site_id")
  triggeredBy String       @map("triggered_by")
  status      DeployStatus @default(running)
  gitCommit   String?      @map("git_commit")
  gitMessage  String?      @map("git_message")
  logOutput   String?      @map("log_output") @db.Text
  durationMs  Int?         @map("duration_ms")
  startedAt   DateTime     @default(now()) @map("started_at")
  finishedAt  DateTime?    @map("finished_at")

  site Site @relation(fields: [siteId], references: [id])
  user User @relation(fields: [triggeredBy], references: [id])

  @@index([siteId, startedAt])
  @@map("deploys")
}

// ─── Cron Jobs ───

model CronJob {
  id          String    @id @default(uuid())
  serverId    String    @map("server_id")
  expression  String
  command     String
  description String?
  lastRunAt   DateTime? @map("last_run_at")
  lastOutput  String?   @map("last_output") @db.Text
  teamId      String    @map("team_id")
  createdAt   DateTime  @default(now()) @map("created_at")

  server Server @relation(fields: [serverId], references: [id])
  team   Team   @relation(fields: [teamId], references: [id])

  @@map("cron_jobs")
}

// ─── Firewall Rules ───

model FirewallRule {
  id        String   @id @default(uuid())
  serverId  String   @map("server_id")
  action    String
  port      Int?
  protocol  String
  source    String   @default("any")
  teamId    String   @map("team_id")
  createdAt DateTime @default(now()) @map("created_at")

  server Server @relation(fields: [serverId], references: [id])
  team   Team   @relation(fields: [teamId], references: [id])

  @@map("firewall_rules")
}

// ─── Notification Channels ───

model NotificationChannel {
  id        String   @id @default(uuid())
  teamId    String   @map("team_id")
  type      String
  config    Json
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  team Team @relation(fields: [teamId], references: [id])

  @@map("notification_channels")
}

// ─── Metrics (time-series) ───

model Metric {
  id          String   @id @default(uuid())
  serverId    String   @map("server_id")
  cpuPercent  Float    @map("cpu_percent")
  ramUsed     Float    @map("ram_used")
  ramTotal    Float    @map("ram_total")
  diskUsed    Float?   @map("disk_used")
  diskTotal   Float?   @map("disk_total")
  netIn       Float?   @map("net_in")
  netOut      Float?   @map("net_out")
  loadAvg     Json?
  recordedAt  DateTime @default(now()) @map("recorded_at")

  server Server @relation(fields: [serverId], references: [id])

  @@index([serverId, recordedAt])
  @@map("metrics")
}

// ─── Uptime Checks ───

model UptimeCheck {
  id                 String    @id @default(uuid())
  siteId             String    @map("site_id")
  url                String
  intervalSeconds    Int       @default(300) @map("interval_seconds")
  status             String    @default("up")
  lastCheckedAt      DateTime? @map("last_checked_at")
  lastStatusChangeAt DateTime? @map("last_status_change_at")
  responseTimeMs     Int?      @map("response_time_ms")

  site      Site              @relation(fields: [siteId], references: [id])
  incidents UptimeIncident[]

  @@map("uptime_checks")
}

// ─── Uptime Incidents ───

model UptimeIncident {
  id              String    @id @default(uuid())
  checkId         String    @map("check_id")
  startedAt       DateTime  @map("started_at")
  resolvedAt      DateTime? @map("resolved_at")
  durationSeconds Int?      @map("duration_seconds")

  check UptimeCheck @relation(fields: [checkId], references: [id])

  @@map("uptime_incidents")
}

// ─── Alert Rules ───

model AlertRule {
  id              String    @id @default(uuid())
  serverId        String?   @map("server_id")
  siteId          String?   @map("site_id")
  type            AlertType
  threshold       Float?
  channel         String
  channelConfig   Json?     @map("channel_config")
  cooldownMinutes Int       @default(15) @map("cooldown_minutes")
  active          Boolean   @default(true)
  teamId          String    @map("team_id")

  team Team @relation(fields: [teamId], references: [id])

  @@map("alert_rules")
}

// ─── Audit Logs ───

model AuditLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  action     String
  targetType String?  @map("target_type")
  targetId   String?  @map("target_id")
  meta       Json?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Job History (audit mirror of BullMQ) ───

model JobHistory {
  id         String    @id @default(uuid())
  queue      String
  type       String
  payload    Json?
  status     JobStatus @default(pending)
  progress   Json?
  error      String?
  attempts   Int       @default(0)
  teamId     String    @map("team_id")
  createdAt  DateTime  @default(now()) @map("created_at")
  startedAt  DateTime? @map("started_at")
  finishedAt DateTime? @map("finished_at")

  team Team @relation(fields: [teamId], references: [id])

  @@index([status, createdAt])
  @@index([queue, createdAt])
  @@map("job_history")
}
